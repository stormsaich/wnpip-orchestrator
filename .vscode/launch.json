{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Orchestrator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "manage.py: register-site",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "register-site",
        "--site-key", "www_example_com",
        "--website", "www.example.com",
        "--display-name", "Example",
        "--listing-url-pattern", "/listing/[0-9]+"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "manage.py: list-sites",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["list-sites"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "manage.py: queue-stats",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["queue-stats"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "manage.py: health",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["health"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "manage.py: crawl-now",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "crawl-now",
        "--site", "www_example_com",
        "--url", "https://www.example.com/listing/12345",
        "--notes", "manual debug crawl"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
