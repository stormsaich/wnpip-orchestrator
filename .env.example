# orchestrator — Environment Variables
# Copy to .env for local development. All variables must be set in docker-compose.yml
# for production. No hardcoded values exist in the service code.

# ── Runtime ───────────────────────────────────────────────────────────────
ENV=development
# Options: development | testing | production

LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Docker: redis://redis:6379

# ── MongoDB (active) ──────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
# Docker: mongodb://mongo-active:27017

MONGO_DB=wnpdc
# Testing: wnpdc_test (use a separate DB to avoid affecting real data)

# ── Job intervals ─────────────────────────────────────────────────────────
RECRAWL_INTERVAL_MINUTES=5
# How often to check crawl_state for listings due re-crawl

SUSPECT_CHECK_INTERVAL_MINUTES=15
# How often to resolve suspect listings

HEALTH_CHECK_INTERVAL_SECONDS=60
# How often to run health checks and emit alerts

QUEUE_REAPER_INTERVAL_MINUTES=30
# How often to recover stalled in-flight items

DISCOVERY_TRIGGER_INTERVAL_HOURS=4
# How often to launch a URL discovery run

# ── Crawl thresholds ──────────────────────────────────────────────────────
INFLIGHT_TTL_SECONDS=300
# Items in-flight longer than this are considered stalled and re-queued

ARCHIVE_AFTER_REMOVED_DAYS=30
# Days in "removed" status before transitioning to "archived"
# For rentals, consider a lower value (e.g. 14) — set per listing_type in config

# ── Discovery ─────────────────────────────────────────────────────────────
# The orchestrator launches discovery as a subprocess.
# The discovery spider must be on PATH (i.e. scrapy must be installed).
# In Docker this is handled by using the spiders image for discovery.
DISCOVERY_COMMAND=scrapy crawl p24_discovery
# Override for testing: DISCOVERY_COMMAND=echo "dry-run discovery"
